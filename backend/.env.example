# Core
PROBIS_ENV=dev
LOG_LEVEL=INFO

# Hot-path decision threshold
EDGE_THRESHOLD=0.05

# Redis (event bus)
REDIS_URL=redis://localhost:6379/0

# Polymarket US market discovery (public API, no auth needed)
POLYMARKET_MARKET_LIMIT=24
POLYMARKET_DISCOVERY_INTERVAL_SECONDS=180

# Polymarket US trading credentials
# 1. Download the Polymarket US iOS app and verify your identity
# 2. Sign in at https://polymarket.us/developer and create an API key
# Docs: https://docs.polymarket.us/getting-started/quickstart
POLYMARKET_KEY_ID=
POLYMARKET_SECRET_KEY=

# Optional Postgres (persistence worker only; not on hot path)
DATABASE_URL=postgresql+asyncpg://probis:probis@localhost:5432/probis

# Ollama (Gemma) for the separate LLM worker
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:2b
LLM_INTERVAL_SECONDS=60
