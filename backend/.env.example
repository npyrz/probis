# Core
PROBIS_ENV=dev
LOG_LEVEL=INFO
FRONTEND_ORIGIN=http://127.0.0.1:5173

# Terminal account surface
PROBIS_ACCOUNT_LABEL=Primary
PROBIS_PAPER_CASH=25000
PROBIS_MAX_TRADE_RISK_PCT=0.02
PROBIS_MAX_DAILY_LOSS=1500

# Deterministic threshold for generating a trade action
EDGE_THRESHOLD=0.04

# Public market metadata lookup
POLYMARKET_GAMMA_API_BASE=https://gamma-api.polymarket.com

# Polymarket trading credentials (optional)
POLYMARKET_KEY_ID=
POLYMARKET_SECRET_KEY=

# Synthesis mode label shown in the UI
PROBIS_AI_MODE=template
