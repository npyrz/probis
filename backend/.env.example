# Core
PROBIS_ENV=dev
LOG_LEVEL=INFO

# Hot-path decision threshold
EDGE_THRESHOLD=0.05

# Redis (event bus)
REDIS_URL=redis://localhost:6379/0

# Polymarket live market discovery + websocket display
POLYMARKET_API_URL=https://gamma-api.polymarket.com
POLYMARKET_MARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_MARKET_LIMIT=24
POLYMARKET_DISCOVERY_INTERVAL_SECONDS=180

# Optional Postgres (persistence worker only; not on hot path)
DATABASE_URL=postgresql+asyncpg://probis:probis@localhost:5432/probis

# Ollama (Gemma) for the separate LLM worker
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:2b
LLM_INTERVAL_SECONDS=60
